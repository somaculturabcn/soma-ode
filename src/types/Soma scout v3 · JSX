// ── MATCHING ENGINE ──────────────────────────────────────────────────────────
function calcFit(opp, artist) {
  const discArtist = artist.disciplinas.map(d => d.toLowerCase());
  const discOpp = (opp.disciplinas||"").toLowerCase().split(",").map(d=>d.trim());
  if (!discArtist.some(d => discOpp.includes(d))) return 0;
  if (opp.country && artist.paises_alvo?.length > 0 && !artist.paises_alvo.includes(opp.country)) return 0;
  let s = 40;
  if ((artist.idiomas||[]).includes(opp.language_required)) s += 20; else s -= 10;
  const hay = `${opp.name} ${opp.type} ${opp.city} ${opp.country}`.toLowerCase();
  const vm = (artist.vocab||[]).filter(v => hay.includes(v.toLowerCase())).length;
  s += Math.min(vm*8, 24);
  if (opp.contact_email) s += 8;
  if (opp.contact_name) s += 4;
  if (opp.url) s += 4;
  return Math.min(100, Math.round(s));
}

function getMatches(artist, opps) {
  return opps.map(o => ({...o, fit: calcFit(o, artist)})).filter(o => o.fit > 0).sort((a,b) => b.fit - a.fit);
}

// ── CSV ──────────────────────────────────────────────────────────────────────
function toCSV(opps, artists) {
  const headers = ["Nome","Tipo","País","Cidade","Datas","Idioma","URL","Contacto Nome","Contacto Email","Região","Disciplinas","Fonte",...artists.map(a=>`FIT_${a.name.split(" ")[0]}`)];
  const rows = opps.map(o => [o.name,o.type,o.country,o.city,o.dates,o.language_required,o.url,o.contact_name||"",o.contact_email||"",o.region,o.disciplinas,o.source||"base",...artists.map(a=>calcFit(o,a))]);
  const e = v => `"${String(v??'').replace(/"/g,'""')}"`;
  return [headers,...rows].map(r=>r.map(e).join(",")).join("\n");
}

