              <div style={{textAlign:"center",paddingTop:48}}>
                <div style={{fontSize:28,opacity:.1,marginBottom:10}}>◎</div>
                <div style={{fontSize:11,color:"var(--color-text-secondary)"}}>Nenhum resultado — o motor filtra por disciplina ({selArtist?.disciplinas.join(", ")}) e países alvo ({selArtist?.paises_alvo?.join(", ")})</div>
              </div>
            )}
            {matches.map(o=>(
              <div key={o.id} style={{background:"var(--color-background-primary)",border:"0.5px solid var(--color-border-tertiary)",borderRadius:9,padding:"11px 14px",marginBottom:7,display:"grid",gridTemplateColumns:"50px 1fr 80px",alignItems:"center",gap:12}}>
                <div style={{textAlign:"center"}}>
                  <div style={{fontSize:18,fontWeight:500,color:fitColor(o.fit)}}>{o.fit}</div>
                  <div style={{fontSize:8,color:"var(--color-text-secondary)",letterSpacing:1}}>FIT</div>
                </div>
                <div>
                  <div style={{display:"flex",alignItems:"center",gap:7,flexWrap:"wrap",marginBottom:3}}>
                    <span style={{fontWeight:500,fontSize:13,color:"var(--color-text-primary)"}}>{o.name}</span>
                    <span style={{background:"var(--color-background-secondary)",color:"var(--color-text-secondary)",fontSize:9,padding:"1px 7px",borderRadius:20,border:"0.5px solid var(--color-border-tertiary)"}}>{o.type}</span>
                    {o.source==="search" && <span style={{background:"var(--color-background-success)",color:"var(--color-text-success)",fontSize:8,padding:"1px 7px",borderRadius:20,letterSpacing:.5}}>NOVO</span>}
                  </div>
                  <div style={{display:"flex",gap:10,flexWrap:"wrap"}}>
                    <span style={{fontSize:11,color:"var(--color-text-secondary)"}}>📍 {o.city||"—"} · {o.country}</span>
                    {o.dates && o.dates!=="/" && <span style={{fontSize:11,color:"var(--color-text-secondary)"}}>🗓 {o.dates}</span>}
                    <span style={{fontSize:11,color:"var(--color-text-secondary)"}}>🌐 {o.language_required||"—"}</span>
                    {o.contact_email && <span style={{fontSize:10,color:"var(--color-text-secondary)"}}>✉ {o.contact_email.split(",")[0].trim().slice(0,35)}</span>}
                  </div>
                </div>
                <div style={{display:"flex",flexDirection:"column",gap:4,alignItems:"flex-end"}}>
                  {o.url && o.url.startsWith("http") && <a href={o.url} target="_blank" rel="noreferrer" style={{fontSize:10,color:"var(--color-text-info)",textDecoration:"none"}}>↗ ver</a>}
                  <span style={{fontSize:9,color:"var(--color-text-secondary)"}}>{o.region}</span>
                </div>
              </div>
            ))}
          </div>
        </div>
      )}

      {/* SCOUT */}
      {tab==="scout" && (
        <div style={{flex:1,overflowY:"auto",padding:20}}>
          <div style={{fontSize:14,fontWeight:500,color:"var(--color-text-primary)",marginBottom:4}}>Motor de busca — 8 pesquisas simultâneas</div>
          <div style={{fontSize:11,color:"var(--color-text-secondary)",lineHeight:1.7,marginBottom:18}}>Usa web search real para encontrar novos festivais, venues e espaços culturais além dos {BASE_DB.length} já na base. Cobre Europa, Brasil, América Latina, Showcases globais e espaços de afrodiáspora.</div>

          <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:18,marginBottom:20}}>
            <div>
              {/* Search categories */}
              <div style={{marginBottom:14}}>
                {buildQueries(selArtist||DEFAULT_ARTISTS[0]).map((q,i)=>(
                  <div key={i} style={{display:"flex",alignItems:"center",gap:8,background:"var(--color-background-secondary)",borderRadius:5,padding:"6px 10px",marginBottom:4}}>
                    <div style={{width:6,height:6,borderRadius:"50%",background:searching&&progress.current===i+1?"#f5c518":searching&&progress.current>i+1?"#22c55e":"var(--color-border-tertiary)",flexShrink:0,transition:"background .3s"}}/>
                    <span style={{fontSize:11,color:searching&&progress.current===i+1?"var(--color-text-primary)":"var(--color-text-secondary)"}}>{q.label}</span>
                  </div>
                ))}
              </div>
              {/* Artist selector */}
              <div style={{display:"flex",gap:6,flexWrap:"wrap",marginBottom:10}}>
                {artists.filter(a=>a.activo).map(a=>(
                  <button key={a.id} onClick={()=>setSelArtist(a)} style={{background:selArtist?.id===a.id?"#f5c518":"var(--color-background-secondary)",color:selArtist?.id===a.id?"#000":"var(--color-text-secondary)",border:`0.5px solid ${selArtist?.id===a.id?"#f5c518":"var(--color-border-tertiary)"}`,padding:"5px 11px",borderRadius:6,cursor:"pointer",fontFamily:"inherit",fontSize:11}}>
                    {a.name}
                  </button>
                ))}
              </div>
              {/* Progress bar */}
              {searching && (
                <div style={{marginBottom:10}}>
                  <div style={{background:"var(--color-background-secondary)",borderRadius:6,height:6,overflow:"hidden"}}>
                    <div style={{height:6,background:"#f5c518",width:`${(progress.current/progress.total)*100}%`,borderRadius:6,transition:"width .5s"}}/>
                  </div>
                  <div style={{fontSize:10,color:"var(--color-text-secondary)",marginTop:4}}>{progress.current}/{progress.total} · {progress.label}</div>
                </div>
              )}
              <button onClick={runSearch} disabled={searching||!selArtist} style={{width:"100%",background:!searching&&selArtist?"#f5c518":"var(--color-background-secondary)",color:!searching&&selArtist?"#000":"var(--color-text-secondary)",border:"none",borderRadius:8,padding:"11px 0",fontWeight:500,cursor:searching||!selArtist?"not-allowed":"pointer",fontSize:12,fontFamily:"inherit",letterSpacing:1,transition:"all .2s"}}>
                {searching?`⟳ Pesquisa ${progress.current} de ${progress.total}...`:"⟳ EXECUTAR BUSCA COMPLETA"}
              </button>
            </div>

            {/* Log */}
            <div>
              <div style={{fontSize:10,color:"var(--color-text-secondary)",letterSpacing:1,marginBottom:8}}>LOG EM TEMPO REAL</div>
              <div ref={logRef} style={{background:"var(--color-background-secondary)",borderRadius:8,padding:14,height:360,overflowY:"auto"}}>
                {searchLog.length===0 ? (
                  <div style={{color:"var(--color-text-secondary)",opacity:.3,fontSize:11}}>Clica em "Executar busca" para iniciar as 8 pesquisas...</div>
                ) : searchLog.map((l,i)=>(
                  <div key={i} style={{display:"flex",gap:8,marginBottom:4}}>
                    <span style={{color:"var(--color-text-secondary)",fontSize:9,minWidth:50,flexShrink:0}}>{l.t}</span>
                    <span style={{fontSize:10,color:l.msg.startsWith("   ✓")?"var(--color-text-success)":l.msg.startsWith("━")?"#f5c518":l.msg.startsWith("   ⚠")?"var(--color-text-warning)":"var(--color-text-primary)"}}>{l.msg}</span>
                  </div>
                ))}
              </div>
            </div>
          </div>

          {/* Stats */}
          <div style={{display:"grid",gridTemplateColumns:"repeat(4,1fr)",gap:10}}>
            {[["Base de dados",BASE_DB.length,"var(--color-text-primary)"],["Via busca IA",extraOpps.length,"var(--color-text-success)"],["Total",allOpps.length,"#f5c518"],["Artistas",artists.filter(a=>a.activo).length,"var(--color-text-primary)"]].map(([l,v,c])=>(
              <div key={l} style={{background:"var(--color-background-primary)",border:"0.5px solid var(--color-border-tertiary)",borderRadius:8,padding:"12px 14px"}}>
                <div style={{fontSize:22,fontWeight:500,color:c}}>{v}</div>
                <div style={{fontSize:9,color:"var(--color-text-secondary)",letterSpacing:1,marginTop:3}}>{l.toUpperCase()}</div>
              </div>
            ))}
          </div>
        </div>
      )}

      {/* ARTISTAS */}
      {tab==="artistas" && (
        <div style={{flex:1,padding:20,overflowY:"auto"}}>
          <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:18}}>
            <div style={{fontSize:14,fontWeight:500,color:"var(--color-text-primary)"}}>Roster</div>
            <button onClick={()=>setEditingArtist("new")} style={{background:"#f5c518",color:"#000",border:"none",padding:"7px 14px",borderRadius:6,fontWeight:500,cursor:"pointer",fontSize:12,fontFamily:"inherit"}}>+ Novo artista</button>
          </div>
          {artists.map(a=>{
            const m = getMatches(a, allOpps);
            return (
              <div key={a.id} style={{background:"var(--color-background-primary)",border:"0.5px solid var(--color-border-tertiary)",borderRadius:10,padding:16,marginBottom:12}}>
                <div style={{display:"flex",justifyContent:"space-between",alignItems:"flex-start",marginBottom:10}}>
                  <div style={{display:"flex",alignItems:"center",gap:10}}>
                    <div style={{width:34,height:34,borderRadius:"50%",background:"var(--color-background-info)",display:"flex",alignItems:"center",justifyContent:"center",fontSize:12,fontWeight:500,color:"var(--color-text-info)"}}>
                      {a.name.split(" ").map(n=>n[0]).slice(0,2).join("")}
                    </div>
                    <div>
                      <div style={{fontWeight:500,fontSize:14,color:"var(--color-text-primary)"}}>{a.name}</div>
                      <div style={{fontSize:11,color:"var(--color-text-secondary)"}}>{a.origin} → {a.base}</div>
                    </div>
                  </div>
                  <div style={{display:"flex",gap:6}}>
                    <button onClick={()=>{setSelArtist(a);setTab("matches");}} style={{background:"var(--color-background-info)",color:"var(--color-text-info)",border:"0.5px solid var(--color-border-info)",padding:"4px 10px",borderRadius:20,cursor:"pointer",fontSize:10,fontFamily:"inherit"}}>{m.length} matches →</button>
                    <button onClick={()=>setEditingArtist(a)} style={{padding:"4px 10px",borderRadius:20,cursor:"pointer",fontSize:10,fontFamily:"inherit"}}>Editar</button>
                  </div>
                </div>
                <div style={{display:"flex",flexWrap:"wrap",gap:5,marginBottom:8}}>
                  {[...a.disciplinas,...(a.paises_alvo||[]),...(a.idiomas||[])].slice(0,8).map(t=>(
                    <span key={t} style={{background:"var(--color-background-secondary)",border:"0.5px solid var(--color-border-tertiary)",color:"var(--color-text-secondary)",padding:"1px 7px",borderRadius:20,fontSize:9}}>{t}</span>
                  ))}
                </div>
                {a.vocab?.length>0 && (
                  <div style={{fontSize:10,color:"var(--color-text-secondary)"}}>🔑 {a.vocab.join(" · ")}</div>
                )}
              </div>
            );
          })}
        </div>
      )}

      {/* EXPORT */}
      {tab==="export" && (
        <div style={{flex:1,padding:20,overflowY:"auto"}}>
          <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:18}}>
            <div style={{background:"var(--color-background-primary)",border:"0.5px solid var(--color-border-tertiary)",borderRadius:12,padding:20}}>
              <div style={{fontWeight:500,fontSize:14,color:"var(--color-text-primary)",marginBottom:8}}>Export CSV → Google Sheets</div>
              <div style={{fontSize:12,color:"var(--color-text-secondary)",lineHeight:1.7,marginBottom:14}}>Exporta todos os {allOpps.length} venues e festivais com scores de fit calculados por artista. Importa directamente no Google Sheets via <em>Ficheiro → Importar → CSV</em>.</div>
              <div style={{background:"var(--color-background-secondary)",borderRadius:8,padding:12,marginBottom:14}}>
                {[["Base Mimosa Tour",BASE_DB.length],["Encontrados via busca",extraOpps.length],["Total venues",allOpps.length],["Artistas no roster",artists.length],["Colunas de fit",artists.map(a=>a.name.split(" ")[0]).join(", ")]].map(([k,v])=>(
                  <div key={k} style={{display:"flex",justifyContent:"space-between",padding:"4px 0",borderBottom:"0.5px solid var(--color-border-tertiary)"}}>
                    <span style={{fontSize:11,color:"var(--color-text-secondary)"}}>{k}</span>
                    <span style={{fontSize:11,color:"var(--color-text-primary)",fontFamily:"monospace"}}>{v}</span>
                  </div>
                ))}
              </div>
              <button onClick={downloadCSV} style={{width:"100%",background:"#f5c518",color:"#000",border:"none",borderRadius:8,padding:11,fontWeight:500,fontSize:12,cursor:"pointer",fontFamily:"inherit"}}>
                ↓ Baixar CSV ({allOpps.length} linhas)
              </button>
            </div>
            <div style={{background:"var(--color-background-primary)",border:"0.5px solid var(--color-border-tertiary)",borderRadius:12,padding:20}}>
              <div style={{fontWeight:500,fontSize:14,color:"var(--color-text-primary)",marginBottom:12}}>Regras do matching</div>
              {[["Disciplina (obrigatório)","Filtro duro — venue fora da disciplina do artista = score 0"],["País alvo (obrigatório)","Filtro duro — se o país não está na lista do artista = score 0"],["Idioma","+ 20 pts se o artista fala o idioma do venue"],["Vocabulário SOMA","+ 8 pts por keyword que aparece no nome/tipo/cidade"],["Contacto email","+ 8 pts se tem email de booking directo"],["Score base","40 pts para quem passa os dois filtros obrigatórios"]].map(([k,v])=>(
                <div key={k} style={{background:"var(--color-background-secondary)",borderRadius:6,padding:"8px 12px",marginBottom:6}}>
                  <div style={{fontSize:11,fontWeight:500,color:"var(--color-text-primary)"}}>{k}</div>
                  <div style={{fontSize:10,color:"var(--color-text-secondary)",marginTop:2}}>{v}</div>
                </div>
              ))}
              <div style={{marginTop:12,padding:"10px 14px",background:"var(--color-background-info)",borderRadius:8}}>
                <div style={{fontSize:11,color:"var(--color-text-info)"}}>💡 Para adicionar um artista com disciplinas diferentes (dança, teatro, circo...), vai ao separador Artistas e cria o perfil. O motor adapta automaticamente os filtros.</div>
              </div>
            </div>
          </div>
        </div>
      )}

      {editingArtist && (
        <ArtistForm
          artist={editingArtist==="new"?null:editingArtist}
          onSave={saved=>{
            if(editingArtist==="new") setArtists(p=>[...p,saved]);
            else setArtists(p=>p.map(a=>a.id===saved.id?saved:a));
            setEditingArtist(null);
          }}
          onClose={()=>setEditingArtist(null)}
        />
      )}
    </div>
  );
}